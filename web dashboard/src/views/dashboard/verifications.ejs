<%- include("../partials/dashboard-layout-top", { pageTitle: "Verification Queue", title, navItems, activePage, currentUser, flash }) %>

<section class="panel">
  <form method="GET" action="/dashboard/verifications" class="inline-form">
    <label>Status</label>
    <select name="status_filter">
      <option value="pending" <%= statusFilter === "pending" ? "selected" : "" %>>pending</option>
      <option value="approved" <%= statusFilter === "approved" ? "selected" : "" %>>approved</option>
      <option value="rejected" <%= statusFilter === "rejected" ? "selected" : "" %>>rejected</option>
    </select>
    <button class="btn" type="submit">Filter</button>
  </form>
</section>

<section class="panel">
  <div class="panel-head">
    <h3>Practice License Reviews</h3>
    <span class="chip"><%= queue.practice_licenses.length %> items</span>
  </div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>User</th>
          <th>Phone</th>
          <th>Governorate</th>
          <th>Status</th>
          <th>Image</th>
          <th>Submitted</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% queue.practice_licenses.forEach((item) => { %>
        <tr>
          <td><%= item.user_name || item.user_id %></td>
          <td><%= item.user_phone %></td>
          <td><%= item.governorate || "-" %></td>
          <td><span class="status"><%= item.status %></span></td>
          <td><a href="<%= backendBaseUrl %><%= item.image_url %>" target="_blank" rel="noreferrer">Open</a></td>
          <td><%= item.submitted_at %></td>
          <td>
            <form method="POST" action="/dashboard/verifications/practice-license/<%= item.user_id %>?status_filter=<%= statusFilter %>" class="action-row">
              <input type="hidden" name="decision" value="approved" />
              <button class="btn success" type="submit">Approve</button>
            </form>
            <form method="POST" action="/dashboard/verifications/practice-license/<%= item.user_id %>?status_filter=<%= statusFilter %>" class="action-row">
              <input type="hidden" name="decision" value="rejected" />
              <input name="rejectionReason" placeholder="Rejection reason" />
              <button class="btn danger" type="submit">Reject</button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% if (!queue.practice_licenses.length) { %>
        <tr><td colspan="7" class="muted">No items.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>

<section class="panel">
  <div class="panel-head">
    <h3>Accredited Courses Reviews</h3>
    <span class="chip"><%= queue.accredited_courses.length %> items</span>
  </div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>User</th>
          <th>Course</th>
          <th>Status</th>
          <th>Image</th>
          <th>Submitted</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% queue.accredited_courses.forEach((item) => { %>
        <tr>
          <td><%= item.user_name || item.user_id %></td>
          <td><%= item.title %></td>
          <td><span class="status"><%= item.status %></span></td>
          <td><a href="<%= backendBaseUrl %><%= item.image_url %>" target="_blank" rel="noreferrer">Open</a></td>
          <td><%= item.submitted_at %></td>
          <td>
            <form method="POST" action="/dashboard/verifications/course/<%= item.user_id %>/<%= item.course_id %>?status_filter=<%= statusFilter %>" class="action-row">
              <input type="hidden" name="decision" value="approved" />
              <button class="btn success" type="submit">Approve</button>
            </form>
            <form method="POST" action="/dashboard/verifications/course/<%= item.user_id %>/<%= item.course_id %>?status_filter=<%= statusFilter %>" class="action-row">
              <input type="hidden" name="decision" value="rejected" />
              <input name="rejectionReason" placeholder="Rejection reason" />
              <button class="btn danger" type="submit">Reject</button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% if (!queue.accredited_courses.length) { %>
        <tr><td colspan="6" class="muted">No items.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>

<%- include("../partials/dashboard-layout-bottom") %>
