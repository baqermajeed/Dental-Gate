<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Dental Gate</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header class="topbar">
      <div>
        <h1>Dental Gate Dashboard</h1>
        <p>Welcome, <%= currentUser.name || currentUser.email || currentUser.phone %></p>
      </div>
      <form method="POST" action="/logout">
        <button type="submit" class="danger">Logout</button>
      </form>
    </header>

    <main class="container">
      <% if (flash) { %>
      <div class="flash <%= flash.type %>"><%= flash.message %></div>
      <% } %>

      <section class="card">
        <h2>Send App Notification</h2>
        <p class="subtitle">
          Backend flow: `POST /notifications/app-announcement` with `X-Internal-Notifications-Key`.
        </p>
        <form method="POST" action="/dashboard/notifications" class="form">
          <label for="notificationTitle">Title</label>
          <input id="notificationTitle" name="title" required maxlength="200" />

          <label for="notificationBody">Body</label>
          <textarea id="notificationBody" name="body" required rows="3" maxlength="2000"></textarea>

          <label class="checkbox" for="sendToAll">
            <input id="sendToAll" name="sendToAll" type="checkbox" />
            Send to all app users
          </label>

          <label for="recipientUserIds">Recipient User IDs</label>
          <textarea
            id="recipientUserIds"
            name="recipientUserIds"
            required
            rows="4"
            placeholder="Put one user_id per line or separate by comma"
          ></textarea>
          <p class="hint">
            مثال: 665cd6ec6f9bba029f95e500, 665cd6ec6f9bba029f95e501
          </p>

          <button type="submit">Send Notification</button>
        </form>
      </section>

      <section class="card">
        <h2>Publish New Slider</h2>
        <p class="subtitle">Backend flow: upload image then create slider (`job_id` + `image_url`).</p>
        <form method="POST" action="/dashboard/sliders" class="form" enctype="multipart/form-data">
          <label for="jobId">Job (job_id)</label>
          <select id="jobId" name="jobId" required>
            <option value="">اختر وظيفة</option>
            <% jobs.forEach((job) => { %>
            <option value="<%= job.id %>">
              <%= job.workplace_name %> - <%= job.required_specialty %> (<%= job.id %>)
            </option>
            <% }) %>
          </select>
          <% if (!jobs.length) { %>
          <p class="hint">لا توجد وظائف في النظام. أنشئ وظيفة من التطبيق أولاً.</p>
          <% } %>

          <label for="imageFile">Slider Image</label>
          <input id="imageFile" name="imageFile" type="file" required accept="image/*" />
          <button type="submit">Publish Slider</button>
        </form>
      </section>

      <section class="card">
        <h2>Backend Sliders</h2>
        <p class="hint">Source: <%= backendBaseUrl %>/home-sliders</p>
        <% if (!sliders.length) { %>
        <p class="empty">No sliders added yet.</p>
        <% } else { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Job ID</th>
                <th>Image</th>
                <th>Created At</th>
              </tr>
            </thead>
            <tbody>
              <% sliders.forEach((slider) => { %>
              <tr>
                <td><%= slider.id %></td>
                <td><%= slider.job_id %></td>
                <td>
                  <a href="<%= slider.image_url_absolute %>" target="_blank" rel="noreferrer">View</a>
                  <img src="<%= slider.image_url_absolute %>" alt="Slider image" class="slider-thumb" />
                </td>
                <td><%= slider.created_at || "-" %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </section>
    </main>
    <script>
      const sendToAllInput = document.getElementById("sendToAll");
      const recipientsInput = document.getElementById("recipientUserIds");

      const toggleRecipientsState = () => {
        const disabled = sendToAllInput.checked;
        recipientsInput.disabled = disabled;
        recipientsInput.required = !disabled;
        if (disabled) {
          recipientsInput.value = "";
          recipientsInput.placeholder = "Disabled when sending to all users";
        } else {
          recipientsInput.placeholder = "Put one user_id per line or separate by comma";
        }
      };

      sendToAllInput.addEventListener("change", toggleRecipientsState);
      toggleRecipientsState();
    </script>
  </body>
</html>
